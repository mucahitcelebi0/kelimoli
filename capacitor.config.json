{
  "appId": "com.kelimoli.app",
  "appName": "Kelimoli",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#F0EBDD"
  },
  "ios": {
    "limitsNavigationsToAppBoundDomains": false,
    "contentInset": "always"
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "*.firebaseapp.com",
      "*.firebaseio.com",
      "*.googleapis.com",
      "*.gstatic.com",
      "*.google.com",
      "*.cloudfunctions.net",
      "kelimoli.firebaseapp.com",
      "kelimoli.firebasestorage.app",
      "*.youtube.com",
      "*.youtube-nocookie.com",
      "*.ytimg.com"
    ]
  }
}
