{
  "name": "kelimoli",
  "version": "0.1.0",
  "private": true,
  "description": "Kelimoli — İngilizce Kelime Akademisi (Türkçe→İngilizce öğrenme uygulaması)",
  "scripts": {
    "build:firebase": "node scripts/build-firebase.js",
    "sync:web": "npm run build:firebase && node scripts/sync-web.js",
